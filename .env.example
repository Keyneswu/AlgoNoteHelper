# Optional: production image tag (git SHA). Leave unset for local `docker compose up --build`.
# IMAGE_TAG=abc123def

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=algonote
POSTGRES_PORT=5432

# Shared secrets (change in production)
INTERNAL_API_SECRET=change-me-internal-api-secret
SECRETS_ENCRYPTION_KEY=change-me-secrets-encryption-key
BETTER_AUTH_SECRET=change-me-better-auth-secret-at-least-32-chars

# URLs — must match what the browser address bar shows (scheme + host + port).
# Production examples: http://YOUR_SERVER_IP:3000  or  https://note.example.com
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Local Next → FastAPI. Docker Compose overrides this to http://api:8000 inside the frontend container.
FASTAPI_BASE_URL=http://127.0.0.1:8000
# Comma-separated; also fed into Better Auth trustedOrigins.
CORS_ORIGINS=http://localhost:3000
# Optional extra origins for Better Auth (comma-separated), e.g. both IP and domain.
TRUSTED_ORIGINS=
API_PORT=8000
FRONTEND_PORT=3000

# Database
# Better Auth / frontend (sync driver)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/algonote
# FastAPI (async driver)
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5432/algonote
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/algonote

# Provider API keys (optional seed values; per-user BYOK in Settings is source of truth at runtime)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
